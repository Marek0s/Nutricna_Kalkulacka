<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainController"
            prefWidth="900"
            prefHeight="640"
            styleClass="app-root"
            stylesheets="@style.css">

    <!-- ===== HEADER ===== -->
    <top>
        <VBox styleClass="header-section" spacing="10">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

            <Label text="🥗  Nutričná kalkulačka" styleClass="app-title"/>

            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="Pohlavie:" style="-fx-font-size:12px;"/>
                <ComboBox fx:id="cbPohlavie" prefWidth="90" style="-fx-font-size:12px;"/>

                <Label text="Vek:" style="-fx-font-size:12px;"/>
                <TextField fx:id="tfVek" prefWidth="56" style="-fx-font-size:12px;"/>

                <Label text="Aktivita:" style="-fx-font-size:12px;"/>
                <ComboBox fx:id="cbAktivita" prefWidth="110" style="-fx-font-size:12px;"/>

                <Button text="✓  Potvrdiť"
                        onAction="#onPotvrdit"
                        styleClass="primary-button"/>

                <Label fx:id="lblOsobaInfo" styleClass="info-label"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <HBox styleClass="content-section" HBox.hgrow="ALWAYS">

            <!-- LEFT PANEL: Katalóg jedál -->
            <VBox spacing="10" styleClass="panel" HBox.hgrow="ALWAYS">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="KATALÓG JEDÁL" styleClass="section-title"/>

                <TableView fx:id="tvKatalog" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNazov" text="Názov"   prefWidth="165"/>
                        <TableColumn fx:id="colKcal"  text="kcal"    prefWidth="52"/>
                        <TableColumn fx:id="colB"     text="B (g)"   prefWidth="52"/>
                        <TableColumn fx:id="colT"     text="T (g)"   prefWidth="52"/>
                        <TableColumn fx:id="colS"     text="S (g)"   prefWidth="52"/>
                    </columns>
                </TableView>

                <Button fx:id="btnPridat"
                        text="+ Pridať do jedálnička"
                        onAction="#onPridat"
                        maxWidth="Infinity"
                        styleClass="primary-button"/>
            </VBox>

            <Separator orientation="VERTICAL" style="-fx-padding:0;"/>

            <!-- RIGHT PANEL: Jedálniček + Príjem + Hodnotenie -->
            <VBox spacing="10" styleClass="panel-right" HBox.hgrow="ALWAYS">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="MÔJ JEDÁLNIČEK" styleClass="section-title"/>

                <ListView fx:id="lvJedalnicek" VBox.vgrow="ALWAYS"/>

                <Button text="🗑  Odstrániť vybrané"
                        onAction="#onOdstranit"
                        maxWidth="Infinity"
                        styleClass="secondary-button"/>

                <Separator/>

                <Label text="DENNÝ PRÍJEM" styleClass="section-title"/>

                <GridPane styleClass="summary-grid" hgap="12" vgap="7">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <!-- Row 0: labels -->
                    <Label text="Kalórie"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-font-size:11px; -fx-text-fill:#4a7a58;"/>
                    <Label text="Bielkoviny"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-font-size:11px; -fx-text-fill:#4a7a58;"/>
                    <Label text="Tuky"
                           GridPane.columnIndex="2" GridPane.rowIndex="0"
                           style="-fx-font-size:11px; -fx-text-fill:#4a7a58;"/>
                    <Label text="Sacharidy"
                           GridPane.columnIndex="3" GridPane.rowIndex="0"
                           style="-fx-font-size:11px; -fx-text-fill:#4a7a58;"/>

                    <!-- Row 1: values -->
                    <Label fx:id="lblKcal"
                           text="0 kcal"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"
                           styleClass="summary-value"/>
                    <Label fx:id="lblBielkoviny"
                           text="0 g"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"
                           styleClass="summary-value"/>
                    <Label fx:id="lblTuky"
                           text="0 g"
                           GridPane.columnIndex="2" GridPane.rowIndex="1"
                           styleClass="summary-value"/>
                    <Label fx:id="lblSacharidy"
                           text="0 g"
                           GridPane.columnIndex="3" GridPane.rowIndex="1"
                           styleClass="summary-value"/>
                </GridPane>

                <Button fx:id="btnHodnotit"
                        text="★  Ohodnotiť jedálniček"
                        onAction="#onHodnotit"
                        maxWidth="Infinity"
                        styleClass="primary-button"/>
            </VBox>

        </HBox>
    </center>

    <!-- ===== FOOTER ===== -->
    <bottom>
        <VBox spacing="8" styleClass="footer-section">
            <padding><Insets top="12" right="20" bottom="14" left="20"/></padding>
            <Label text="HODNOTENIE" styleClass="section-title"/>
            <TextArea fx:id="taHodnotenie"
                      editable="false"
                      prefHeight="80"
                      wrapText="true"
                      promptText="Tu sa zobrazí hodnotenie jedálnička..."/>
        </VBox>
    </bottom>

</BorderPane>
