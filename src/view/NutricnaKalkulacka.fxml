<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainController"
            prefWidth="850"
            prefHeight="620"
            styleClass="app-root"
            stylesheets="@style.css">

    <top>
        <VBox spacing="10" styleClass="header-section">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Nutričná kalkulačka" styleClass="app-title"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Pohlavie:"/>
                <ComboBox fx:id="cbPohlavie" prefWidth="100"/>

                <Label text="Vek:"/>
                <TextField fx:id="tfVek" prefWidth="60"/>

                <Label text="Aktivita:"/>
                <ComboBox fx:id="cbAktivita" prefWidth="120"/>

                <Button text="Potvrdiť" onAction="#onPotvrdit" styleClass="primary-button"/>

                <Label fx:id="lblOsobaInfo" styleClass="info-label"/>
            </HBox>

            <Separator/>
        </VBox>
    </top>

    <center>
        <HBox spacing="12" styleClass="content-section">
            <padding><Insets top="5" right="10" bottom="5" left="10"/></padding>

            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="panel">
                <Label text="Katalóg jedál:" styleClass="section-title"/>

                <TableView fx:id="tvKatalog" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNazov" text="Názov" prefWidth="160"/>
                        <TableColumn fx:id="colKcal"  text="kcal"  prefWidth="55"/>
                        <TableColumn fx:id="colB"     text="B(g)"  prefWidth="55"/>
                        <TableColumn fx:id="colT"     text="T(g)"  prefWidth="55"/>
                        <TableColumn fx:id="colS"     text="S(g)"  prefWidth="55"/>
                    </columns>
                </TableView>

                <Button fx:id="btnPridat"
                        text="Pridať do jedálnička"
                        onAction="#onPridat"
                        maxWidth="Infinity"
                        styleClass="primary-button"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="panel">
                <Label text="Môj jedálniček:" styleClass="section-title"/>

                <ListView fx:id="lvJedalnicek" VBox.vgrow="ALWAYS"/>

                <Button text="Odstrániť vybrané"
                        onAction="#onOdstranit"
                        maxWidth="Infinity"
                        styleClass="secondary-button"/>

                <Separator/>

                <Label text="Denný príjem:" styleClass="section-title"/>

                <GridPane hgap="10" vgap="6" styleClass="summary-grid">
                    <Label text="Kalórie:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblKcal" GridPane.columnIndex="1" GridPane.rowIndex="0" text="0 kcal" styleClass="summary-value"/>

                    <Label text="Bielkoviny:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblBielkoviny" GridPane.columnIndex="1" GridPane.rowIndex="1" text="0 g" styleClass="summary-value"/>

                    <Label text="Tuky:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="lblTuky" GridPane.columnIndex="1" GridPane.rowIndex="2" text="0 g" styleClass="summary-value"/>

                    <Label text="Sacharidy:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="lblSacharidy" GridPane.columnIndex="1" GridPane.rowIndex="3" text="0 g" styleClass="summary-value"/>
                </GridPane>

                <Separator/>

                <Button fx:id="btnHodnotit"
                        text="Ohodnotiť jedálniček"
                        onAction="#onHodnotit"
                        maxWidth="Infinity"
                        styleClass="primary-button"/>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <VBox spacing="8" styleClass="footer-section">
            <padding><Insets top="5" right="10" bottom="10" left="10"/></padding>
            <Separator/>
            <Label text="Hodnotenie:" styleClass="section-title"/>
            <TextArea fx:id="taHodnotenie"
                      editable="false"
                      prefHeight="100"
                      wrapText="true"
                      promptText="Tu sa zobrazí hodnotenie jedálnička..."/>
        </VBox>
    </bottom>

</BorderPane>
